{
  "name": "nodeskclaw",
  "version": "0.1.0",
  "private": true,
  "description": "OpenClaw channel plugin for NoDeskClaw workspace collaboration",
  "type": "module",
  "devDependencies": {
    "openclaw": "workspace:*"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
